# Supabase — copia questo file in .env e compila i valori
# Trovi le key su: Supabase Dashboard > Settings > API

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supporta sia il formato nuovo (sb_publishable_...) che il vecchio (eyJ...)
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_XXXX

# Segreto condiviso tra app e Edge Function
# Imposta lo stesso valore anche su: Edge Functions > transcribe-audio > Secrets > FUNCTION_SECRET
EXPO_PUBLIC_FUNCTION_SECRET=vo_secret_change_me

# RevenueCat — API Key pubblica (dashboard.revenuecat.com > App Settings > API Keys)
EXPO_PUBLIC_REVENUECAT_API_KEY=appl_XXXX
